# ============================================
# 1000FPS — Переменные окружения
# ============================================
# Скопируйте этот файл в .env и заполните значениями

# ============================================
# DATABASE
# ============================================
# PostgreSQL (используется pg-local контейнер)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/site-1000fps?schema=public"

# Redis (для кэша и сессий)
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT & AUTH
# ============================================
# Секретный ключ для JWT (минимум 32 символа)
# Сгенерировать: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================
# APP URLs
# ============================================
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"
API_URL="http://localhost:3001"
PARSER_URL="http://localhost:3003"

# ============================================
# EMAIL (SMTP)
# ============================================
# Для отправки уведомлений (SendGrid, SMTP.ru, Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@1000fps.ru"

# ============================================
# FILE STORAGE (S3-compatible)
# ============================================
# Yandex Object Storage / Cloudflare R2 / MinIO
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_REGION="ru-central1"
S3_BUCKET="site-1000fps-storage"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_PUBLIC_URL="https://your-bucket.storage.yandexcloud.net"

# ============================================
# PAYMENT GATEWAY
# ============================================
# ЮKassa / CloudPayments / Тинькофф Касса
PAYMENT_API_KEY="your-payment-api-key"
PAYMENT_SECRET="your-payment-secret"
PAYMENT_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# TELEGRAM (для уведомлений)
# ============================================
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_ADMIN_CHAT_ID="-1001234567890"

# ============================================
# MEILISEARCH (поиск)
# ============================================
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# ============================================
# SENTRY (мониторинг ошибок)
# ============================================
SENTRY_DSN="https://your-sentry-dsn@o0.ingest.sentry.io/0"
SENTRY_ENVIRONMENT="development"

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# CORS
# ============================================
CORS_ORIGIN="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# ============================================
# PARSER
# ============================================
# Настройки парсера для импорта товаров
PARSER_ENABLED=true
PARSER_INTERVAL_MINUTES=60
PARSER_MAX_CONCURRENT=5
PARSER_TIMEOUT_MS=30000

# ============================================
# NODE
# ============================================
NODE_ENV="development"
PORT=3001
