# ============================================================
# Переменные окружения для 1000fps
# Скопируйте этот файл в .env.local и настройте под себя
# ============================================================

# ------------------------------------------------------------
# Приложение
# ------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# База данных PostgreSQL
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fps1000?schema=public

# Для Docker (внутри сети)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fps1000?schema=public

# ------------------------------------------------------------
# Redis (кэширование)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Для Docker (внутри сети)
# REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# Парсер
# ------------------------------------------------------------
PARSER_URL=http://localhost:3005
PARSER_UI_URL=http://localhost:3006

# Для Docker
# PARSER_URL=http://parser:3005
# PARSER_UI_URL=http://parser-ui:3006

# ------------------------------------------------------------
# Безопасность
# ------------------------------------------------------------
JWT_SECRET=your-secret-key-change-in-production
COOKIE_SECRET=your-cookie-secret-change-in-production

# ------------------------------------------------------------
# Wildberries Parser
# ------------------------------------------------------------
WB_DEST=123585942

# ------------------------------------------------------------
# Порты
# ------------------------------------------------------------
POSTGRES_PORT=5432
APP_PORT=3000
PARSER_PORT=3005
PARSER_UI_PORT=3006
REDIS_PORT=6379

# ------------------------------------------------------------
# Загрузка файлов
# ------------------------------------------------------------
UPLOAD_DIR=./public/uploads
MAX_UPLOAD_SIZE=10485760
