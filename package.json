{
  "name": "site-1000fps",
  "version": "1.0.0",
  "private": true,
  "description": "Интернет-магазин компьютерной техники 1000FPS",
  "author": "1000FPS Team",
  "license": "UNLICENSED",
  "keywords": [
    "ecommerce",
    "nextjs",
    "nestjs",
    "typescript",
    "prisma"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@site-1000fps/api",
    "dev:store": "turbo run dev --filter=@site-1000fps/storefront",
    "dev:admin": "turbo run dev --filter=@site-1000fps/admin",
    "dev:parser": "turbo run dev --filter=parser",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@site-1000fps/api",
    "build:store": "turbo run build --filter=@site-1000fps/storefront",
    "build:admin": "turbo run build --filter=@site-1000fps/admin",
    "build:parser": "turbo run build --filter=parser",
    "start": "turbo run start",
    "start:api": "turbo run start --filter=@site-1000fps/api",
    "start:store": "turbo run start --filter=@site-1000fps/storefront",
    "start:admin": "turbo run start --filter=@site-1000fps/admin",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter=api prisma generate",
    "db:migrate": "pnpm --filter=api prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter=api prisma migrate deploy",
    "db:migrate:reset": "pnpm --filter=api prisma migrate reset",
    "db:seed": "pnpm --filter=api prisma db seed",
    "db:studio": "pnpm --filter=api prisma studio",
    "db:pull": "pnpm --filter=api prisma db pull",
    "db:push": "pnpm --filter=api prisma db push",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "parser:run": "pnpm --filter=parser run:parse",
    "parser:test": "pnpm --filter=parser test",
    "prepare": "husky install",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^20.11.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
