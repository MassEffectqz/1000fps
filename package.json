    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vitest": "^4.1.2"
