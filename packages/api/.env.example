# ============================================
# API Service — Переменные окружения
# ============================================

# NODE
NODE_ENV=development
PORT=3001

# DATABASE
# Используем твой pg-local контейнер
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/site-1000fps?schema=public"

# REDIS
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="dev-secret-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:3002,http://localhost:3003"

# RATE LIMITING
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# FILE STORAGE (S3)
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_REGION="ru-central1"
S3_BUCKET="site-1000fps-dev"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_PUBLIC_URL="https://your-bucket.storage.yandexcloud.net"

# EMAIL (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@1000fps.ru"

# PAYMENT
PAYMENT_API_KEY="dev-payment-key"
PAYMENT_SECRET="dev-payment-secret"
PAYMENT_WEBHOOK_SECRET="dev-webhook-secret"

# TELEGRAM
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_ADMIN_CHAT_ID="-1001234567890"

# MEILISEARCH
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="dev-meilisearch-key"

# SENTRY
SENTRY_DSN=""
SENTRY_ENVIRONMENT=development

# PARSER
PARSER_API_URL="http://localhost:3003"
PARSER_ENABLED=true
